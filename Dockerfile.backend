# ============================================================
# Axis Underwriting Agent — App Tier Image (App Subnet)
# Full Node.js app: Express API, Socket.io, Entra ID SSO session
# handling, Bull/Redis worker (Textract -> Claude -> external
# verification APIs via Middleware -> calculation engine -> DOCX),
# and all business logic. This is the single stateful process that
# owns sessions — the frontend (Nginx) image proxies everything
# dynamic here so authentication keeps working correctly.
# ============================================================

# ---- deps stage: install only production deps ----
FROM node:20-slim AS deps
WORKDIR /usr/src/app

COPY package.json ./
# Once you commit a package-lock.json, switch to:
#   RUN npm ci --omit=dev && npm cache clean --force
RUN npm install --omit=dev && npm cache clean --force

# ---- runtime stage ----
FROM node:20-slim AS runtime
WORKDIR /usr/src/app

ENV NODE_ENV=production

# Non-root user for security
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Copy production node_modules from deps stage
COPY --from=deps /usr/src/app/node_modules ./node_modules

# Copy application source
# (sharp has native bindings — node_modules must come from deps stage,
#  not from a local install on a different OS/arch)
COPY server.js ./
COPY lib ./lib
COPY config ./config
COPY scripts ./scripts
COPY public ./public
COPY compliance ./compliance
COPY package.json ./

RUN chown -R appuser:appuser /usr/src/app
USER appuser

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:'+(process.env.PORT||3000)+'/health',(r)=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"

CMD ["node", "server.js"]
