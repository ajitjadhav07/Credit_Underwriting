# Axis Underwriting Agent — Environment Variables
# Copy to .env for local dev. In AWS, these are injected via Secrets Manager
# + EC2 environment / ECS task definition, never committed to git.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
PORT=10000
NODE_ENV=production

# ---------------------------------------------------------------------------
# Amazon Bedrock — document data EXTRACTION (primary path)
# Auth comes from the EC2/task IAM role (bedrock:InvokeModel,
# bedrock:InvokeModelWithResponseStream) — no API key needed.
# Verify the model ID/inference profile is enabled in this account+region:
#   aws bedrock list-inference-profiles --region ap-south-1
# ---------------------------------------------------------------------------
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
# Optional: per-model overrides as JSON, e.g. {"claude-sonnet-4-20250514":"..."}
# BEDROCK_MODEL_MAP=

# ---------------------------------------------------------------------------
# Direct Anthropic API — legacy fallback only (used automatically if
# AWS_REGION is unset, e.g. local dev without AWS credentials configured)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# AWS — S3 (system of record: assessments, masters, audit logs, API responses)
# ---------------------------------------------------------------------------
AWS_REGION=ap-south-1
S3_BUCKET_NAME=axis-underwriting-documents
# On EC2 these should come from the instance IAM role, not static keys.
# Only set the two below for local development:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# AWS Textract — scanned-document OCR (replaces Google Vision)
# Uses the same AWS credentials/IAM role as S3 above. The EC2 instance
# role needs: textract:DetectDocumentText
# No separate API key required.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Redis / Bull Queue
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AFL Middleware Gateways — rebuilt against real API_Collections.zip specs.
# There are THREE distinct hosts/gateways, not one generic Middleware URL:
#   - DataPower    -> Karza ITR-V + EPFO UAN OTP/Auth
#   - Internal GW  -> CIBIL Commercial + Novel (bank statement engine)
#   - Pennant      -> called DIRECTLY, no Middleware, no auth headers
# All (except Pennant) share the same header convention:
#   serviceCode, callerIdentification, authorizationKey, trackingId
# ---------------------------------------------------------------------------
MIDDLEWARE_DATAPOWER_URL=https://afldatapoweruat.axisb.com:8441
MIDDLEWARE_CIBIL_COMMERCIAL_URL=http://10.0.218.39:7083
MIDDLEWARE_NOVEL_UPLOAD_URL=http://10.0.218.39:7084
MIDDLEWARE_NOVEL_URL=http://10.0.218.39:7083
MIDDLEWARE_CIBIL_SOAP_URL=http://192.168.127.69:8096/BureauOneInternalService.svc
MIDDLEWARE_AUTH_KEY=
MIDDLEWARE_CALLER_ID=INDUS
MIDDLEWARE_TIMEOUT_MS=30000

# Pennant LOS — direct connection, no Middleware (confirmed from sample:
# plain JSON POST, no auth headers at all)
PENNANT_BASE_URL=https://afloasuatweb.axisb.com:8070
PENNANT_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Microsoft Entra ID / Office 365 SSO (HIL underwriter login)
# ---------------------------------------------------------------------------
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
SESSION_SECRET=8aab5a2654a8b0555c0eb46a5fa10fdefc0058ec41df3daa7efe998dc80ead3a74cc381e957c3623d41ed23315d72ceb52f69b3a203ba8f497cd50494258da6c
JWT_SECRET=4fa3ca9bb25cbb71758328aad4a054268d671211de35f38ce9457878bc1f84ced990339a31d1d7d6486fe743e36a9546e2d22d141293114c20741c1fa41ec619
