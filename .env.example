# Axis Underwriting Agent — Environment Variables
# Copy to .env for local dev. In AWS, these are injected via Secrets Manager
# + EC2 environment / ECS task definition, never committed to git.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
PORT=10000
NODE_ENV=production

# ---------------------------------------------------------------------------
# Anthropic Claude — document data EXTRACTION only (not the decision engine)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# AWS — S3 (system of record: assessments, masters, audit logs, API responses)
# ---------------------------------------------------------------------------
AWS_REGION=ap-south-1
S3_BUCKET_NAME=axis-underwriting-documents
# On EC2 these should come from the instance IAM role, not static keys.
# Only set the two below for local development:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# AWS Textract — scanned-document OCR (replaces Google Vision)
# Uses the same AWS credentials/IAM role as S3 above. The EC2 instance
# role needs: textract:DetectDocumentText
# No separate API key required.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Redis / Bull Queue
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Centralized Middleware Gateway (DataPower)
# All external data-source calls (NSDL, CIBIL, Perfios, Karza) are routed
# through this single Middleware endpoint. The App EC2 never calls these
# third-party providers directly — Middleware owns encryption/decryption
# and the actual upstream provider credentials.
# ---------------------------------------------------------------------------
MIDDLEWARE_BASE_URL=
MIDDLEWARE_CLIENT_ID=underwriting-agent
MIDDLEWARE_CLIENT_KEY=
MIDDLEWARE_TIMEOUT_MS=30000

# Per-provider route overrides (only needed if Middleware paths differ
# from the defaults baked into lib/external-apis-manager.js)
# MIDDLEWARE_PATH_NSDL=/v1/nsdl/pan-verify
# MIDDLEWARE_PATH_CIBIL=/v1/cibil/report
# MIDDLEWARE_PATH_PERFIOS=/v1/perfios/bank-analysis
# MIDDLEWARE_PATH_KARZA_ITR=/v1/karza/itr-verify
# MIDDLEWARE_PATH_KARZA_GST=/v1/karza/gst-verify

# ---------------------------------------------------------------------------
# Microsoft Entra ID / Office 365 SSO (HIL underwriter login)
# ---------------------------------------------------------------------------
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
SESSION_SECRET=8aab5a2654a8b0555c0eb46a5fa10fdefc0058ec41df3daa7efe998dc80ead3a74cc381e957c3623d41ed23315d72ceb52f69b3a203ba8f497cd50494258da6c
JWT_SECRET=4fa3ca9bb25cbb71758328aad4a054268d671211de35f38ce9457878bc1f84ced990339a31d1d7d6486fe743e36a9546e2d22d141293114c20741c1fa41ec619
